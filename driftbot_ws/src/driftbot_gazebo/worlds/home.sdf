        </inertial>
      </link>
    </model>

    <!-- can: straight ahead of spawn on y=9 (+x row to collection box) -->
    <model name="can">
      <pose>1.5 9.0 0.065 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <pose>0 0 0 0 0 0</pose>
          <geometry><cylinder><radius>0.04</radius><length>0.13</length></cylinder></geometry>
          <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface>
        </collision>
        <visual name="vis">
          <pose>0 0 0 0 0 0</pose>
          <geometry><cylinder><radius>0.04</radius><length>0.13</length></cylinder></geometry>
          <material><ambient>0.9 0.5 0.1 1</ambient><diffuse>0.9 0.5 0.1 1</diffuse></material>
        </visual>
        <inertial><mass>0.1</mass>

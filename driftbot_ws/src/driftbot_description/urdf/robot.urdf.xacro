<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="driftbot">

  <xacro:include filename="$(find driftbot_description)/urdf/materials.xacro"/>
  <xacro:include filename="$(find driftbot_description)/urdf/inertia_macros.xacro"/>
  <xacro:include filename="$(find driftbot_description)/urdf/base.xacro"/>
  <xacro:include filename="$(find driftbot_description)/urdf/torso.xacro"/>
  <xacro:include filename="$(find driftbot_description)/urdf/arm_active.xacro"/>
  <xacro:include filename="$(find driftbot_description)/urdf/arm_cosmetic.xacro"/>
  <xacro:include filename="$(find driftbot_description)/urdf/sensors.xacro"/>
  <xacro:include filename="$(find driftbot_description)/urdf/ros2_control.xacro"/>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_fl_joint</left_joint>
      <left_joint>wheel_rl_joint</left_joint>
      <right_joint>wheel_fr_joint</right_joint>
      <right_joint>wheel_rr_joint</right_joint>
      <!-- Track width: 2 * wheel_track_half_y (base.xacro). -->
      <wheel_separation>0.55</wheel_separation>
      <wheel_radius>0.10</wheel_radius>
      <max_linear_velocity>0.8</max_linear_velocity>
      <max_angular_velocity>1.5</max_angular_velocity>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

  <!-- Contact system is required by TouchPlugin and contact sensors. -->
  <gazebo>
    <plugin filename="gz-sim-contact-system"
            name="gz::sim::systems::Contact"/>
  </gazebo>

  <!-- Magnetic pickup behavior for floor objects.
       Targets in home.sdf:
         - can
         - ball
         - toy_block_1
         - toy_block_2
         - toy_cylinder_1
         - toy_block_3
       All targets use child_link=link.

       Control topics (Gazebo transport):
         - /magnet_on  (gz.msgs.Empty): attach targets
         - /magnet_off (gz.msgs.Empty): detach targets
  -->
  <gazebo>
    <plugin filename="gz-sim-detachable-joint-system"
            name="gz::sim::systems::DetachableJoint">
      <parent_link>magnet_zone_link</parent_link>
      <child_model>can</child_model>
      <child_link>link</child_link>
      <attach_topic>/can/attach</attach_topic>
      <detach_topic>/can/detach</detach_topic>
      <detach_on_start>true</detach_on_start>
    </plugin>
    <plugin filename="gz-sim-detachable-joint-system"
            name="gz::sim::systems::DetachableJoint">
      <parent_link>magnet_zone_link</parent_link>
      <child_model>ball</child_model>
      <child_link>link</child_link>
      <attach_topic>/ball/attach</attach_topic>
      <detach_topic>/ball/detach</detach_topic>
      <detach_on_start>true</detach_on_start>
    </plugin>
    <plugin filename="gz-sim-detachable-joint-system"
            name="gz::sim::systems::DetachableJoint">
      <parent_link>magnet_zone_link</parent_link>
      <child_model>toy_block_1</child_model>
      <child_link>link</child_link>
      <attach_topic>/toy_block_1/attach</attach_topic>
      <detach_topic>/toy_block_1/detach</detach_topic>
      <detach_on_start>true</detach_on_start>
    </plugin>
    <plugin filename="gz-sim-detachable-joint-system"
            name="gz::sim::systems::DetachableJoint">
      <parent_link>magnet_zone_link</parent_link>
      <child_model>toy_block_2</child_model>
      <child_link>link</child_link>
      <attach_topic>/toy_block_2/attach</attach_topic>
      <detach_topic>/toy_block_2/detach</detach_topic>
      <detach_on_start>true</detach_on_start>
    </plugin>
    <plugin filename="gz-sim-detachable-joint-system"
            name="gz::sim::systems::DetachableJoint">
      <parent_link>magnet_zone_link</parent_link>
      <child_model>toy_cylinder_1</child_model>
      <child_link>link</child_link>
      <attach_topic>/toy_cylinder_1/attach</attach_topic>
      <detach_topic>/toy_cylinder_1/detach</detach_topic>
      <detach_on_start>true</detach_on_start>
    </plugin>
    <plugin filename="gz-sim-detachable-joint-system"
            name="gz::sim::systems::DetachableJoint">
      <parent_link>magnet_zone_link</parent_link>
      <child_model>toy_block_3</child_model>
      <child_link>link</child_link>
      <attach_topic>/toy_block_3/attach</attach_topic>
      <detach_topic>/toy_block_3/detach</detach_topic>
      <detach_on_start>true</detach_on_start>
    </plugin>

    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_on"/>
      <output type="gz.msgs.Empty" topic="/can/attach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_on"/>
      <output type="gz.msgs.Empty" topic="/ball/attach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_on"/>
      <output type="gz.msgs.Empty" topic="/toy_block_1/attach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_on"/>
      <output type="gz.msgs.Empty" topic="/toy_block_2/attach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_on"/>
      <output type="gz.msgs.Empty" topic="/toy_cylinder_1/attach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_on"/>
      <output type="gz.msgs.Empty" topic="/toy_block_3/attach"/>
    </plugin>

    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_off"/>
      <output type="gz.msgs.Empty" topic="/can/detach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_off"/>
      <output type="gz.msgs.Empty" topic="/ball/detach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_off"/>
      <output type="gz.msgs.Empty" topic="/toy_block_1/detach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_off"/>
      <output type="gz.msgs.Empty" topic="/toy_block_2/detach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_off"/>
      <output type="gz.msgs.Empty" topic="/toy_cylinder_1/detach"/>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system"
            name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Empty" topic="/magnet_off"/>
      <output type="gz.msgs.Empty" topic="/toy_block_3/detach"/>
    </plugin>
  </gazebo>

</robot>

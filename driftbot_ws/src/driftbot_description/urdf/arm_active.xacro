<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="arm_scale" value="0.0018 0.0018 0.0018"/>
  <xacro:property name="l1_visual_xyz" value="0 0 -0.0481"/>
  <xacro:property name="l2_visual_xyz" value="0 0 0"/>
  <xacro:property name="l3_visual_xyz" value="0.08169 0.00595 0.00146"/>
  <xacro:property name="l4_visual_xyz" value="0 0.20 0"/>

  <xacro:property name="shoulder_joint_xyz" value="0 0 0.06858"/>
  <xacro:property name="elbow_joint_xyz" value="0 0 0"/>
  <xacro:property name="forearm_tip_xyz" value="0 -0.185 0"/>
  <xacro:property name="wrist_tip_xyz" value="0.17751 0 0"/>
  <xacro:property name="magnet_gripper_xyz" value="0 0.35 0"/>
  <!-- magnet R -->
  <xacro:property name="magnet_radius" value="0.13"/>
  <xacro:property name="magnet_visual_radius" value="0.13"/>

  <!-- home rad ref -->
  <xacro:property name="arm_home_shoulder" value="0.38"/>
  <xacro:property name="arm_home_elbow" value="-0.88"/>
  <xacro:property name="arm_home_wrist" value="0.06"/>

  <!-- arm base -->
  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://driftbot_description/meshes/base.stl" scale="${arm_scale}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.07"/></geometry>
    </collision>
    <xacro:inertia_box m="0.092" lx="0.05" ly="0.05" lz="0.07"/>
  </link>

  <joint name="arm_base_joint" type="fixed">
  <parent link="torso_link"/>
  <child  link="arm_base_link"/>
  <origin xyz="0.0 ${torso_ly/2.0} 0.04" rpy="-1.5708 0 0"/>
</joint>

  <!-- shoulder -->
  <link name="upper_arm_link">
    <visual>
      <origin xyz="${l1_visual_xyz}" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://driftbot_description/meshes/link1.stl" scale="${arm_scale}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.10"/></geometry>
    </collision>
    <xacro:inertia_cylinder_z_at m="0.187" r="0.025" l="0.10" ox="0" oy="0" oz="0.05"/>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="arm_base_link"/>
    <child  link="upper_arm_link"/>
    <origin xyz="${shoulder_joint_xyz}" rpy="0 3.14159 0"/>
    <axis xyz="0 0 1"/>
    <!-- limit inboard -->
    <limit lower="-0.18" upper="1.48" effort="20.0" velocity="1.0"/>
    <dynamics damping="1.2" friction="0.35"/>
  </joint>

  <!-- elbow -->
  <link name="forearm_link">
    <visual>
      <origin xyz="${l2_visual_xyz}" rpy="0 0 -1.5708"/>
      <geometry>
        <mesh filename="package://driftbot_description/meshes/link2.stl" scale="${arm_scale}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0.07 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.022" length="0.15"/></geometry>
    </collision>
    <xacro:inertia_cylinder_x_at m="0.044" r="0.022" l="0.15" ox="0.07" oy="0" oz="0"/>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child  link="forearm_link"/>
    <origin xyz="${elbow_joint_xyz}" rpy="0 1.5708 -1.5708"/>
    <axis xyz="0 0 1"/>
    <!-- no self-hit -->
    <limit lower="-2.05" upper="0.12" effort="15.0" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.28"/>
  </joint>

  <!-- wrist -->
<link name="wrist_link">
  <visual>
    <origin xyz="${l3_visual_xyz}" rpy="0 0 -0.0427"/>
    <geometry>
      <mesh filename="package://driftbot_description/meshes/link3.stl" scale="${arm_scale}"/>
    </geometry>
    <material name="grey"/>
  </visual>
  <collision>
    <origin xyz="0.09 0 0" rpy="0 1.5708 0"/>
    <geometry><cylinder radius="0.020" length="0.18"/></geometry>
  </collision>
  <xacro:inertia_cylinder_x_at m="0.207" r="0.020" l="0.18" ox="0.09" oy="0" oz="0"/>
</link>

<joint name="wrist_joint" type="revolute">
  <parent link="forearm_link"/>
  <child  link="wrist_link"/>
  <origin xyz="${forearm_tip_xyz}" rpy="0 3.14159 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="-0.95" upper="1.15" effort="8.0" velocity="1.5"/>
  <dynamics damping="0.55" friction="0.18"/>
</joint>

  <!-- gripper -->
  <link name="gripper_link">
    <visual>
      <origin xyz="${l4_visual_xyz}" rpy="0 0 1.5281"/>
      <geometry>
        <mesh filename="package://driftbot_description/meshes/link4.stl" scale="${arm_scale}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.018" length="0.10"/></geometry>
    </collision>
    <xacro:inertia_cylinder_x_at m="0.081" r="0.018" l="0.10" ox="0.05" oy="0" oz="0"/>
  </link>

  <joint name="gripper_joint" type="fixed">
    <parent link="wrist_link"/>
    <child  link="gripper_link"/>
    <origin xyz="${wrist_tip_xyz}" rpy="3.14159 0 1.5708"/>
  </joint>

  <link name="magnet_zone_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${magnet_visual_radius}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision name="magnet_zone_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${magnet_radius}"/>
      </geometry>
    </collision>
    <xacro:inertia_sphere m="0.001" r="${magnet_radius}"/>
  </link>

  <joint name="magnet_zone_joint" type="fixed">
    <parent link="gripper_link"/>
    <child  link="magnet_zone_link"/>
    <origin xyz="${magnet_gripper_xyz}" rpy="0 0 0"/>
  </joint>

  <!-- magnet sdf -->
  <gazebo reference="magnet_zone_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <gazebo reference="magnet_zone_link">
    <turnGravityOff>true</turnGravityOff>
    <sensor name="magnet_zone_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <contact>
        <collision>magnet_zone_collision</collision>
      </contact>
    </sensor>
  </gazebo>

  <gazebo reference="arm_base_link">
    <turnGravityOff>true</turnGravityOff>
  </gazebo>
  <gazebo reference="upper_arm_link">
    <turnGravityOff>true</turnGravityOff>
  </gazebo>
  <gazebo reference="forearm_link">
    <turnGravityOff>true</turnGravityOff>
  </gazebo>
  <gazebo reference="wrist_link">
    <turnGravityOff>true</turnGravityOff>
  </gazebo>
  <gazebo reference="gripper_link">
    <turnGravityOff>true</turnGravityOff>
  </gazebo>

</robot>